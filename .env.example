# SignalSage Environment Variables
# Copy this file to .env.local and fill in your values

# ─── Splunk REST API Connection ───────────────────────────────────────────────
# The REST API runs on port 8089 (not the web UI port 8000)
SPLUNK_HOST=localhost
SPLUNK_PORT=8089
SPLUNK_TOKEN=
SPLUNK_INDEX=main

# ─── Splunk HEC (HTTP Event Collector) ───────────────────────────────────────
# Used by the data ingestion script (scripts/ingest-demo-data.js)
# HEC typically runs on port 8088 with SSL
SPLUNK_HEC_TOKEN=
SPLUNK_HEC_PORT=8088

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to true to enable live Splunk queries (requires SPLUNK_HOST and SPLUNK_TOKEN)
ALLOW_LIVE_SPL=false

# Time window cap for Splunk queries (hours). Set to 8760 for 1 year max.
MAX_TIME_WINDOW_HOURS=8760

# ─── Optional ─────────────────────────────────────────────────────────────────
# OpenAI API key for AI-enhanced summaries (not required for core functionality)
OPENAI_API_KEY=

# ─── Splunk AI Assistant (Cloud-connected) ────────────────────────────────────
# When approved, these enable Splunk AI Assistant for NL→SPL, explanations, and summaries
SPLUNK_AI_PROXY_URL=
SPLUNK_AI_CLOUD_TOKEN=
